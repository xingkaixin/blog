---
import "@fontsource/outfit/400.css";
import "@fontsource/outfit/500.css";
import "@fontsource/outfit/700.css";
import "@fontsource/jetbrains-mono/400.css";
import "@fontsource/jetbrains-mono/600.css";
import { SearchDialog } from "@/components/search-dialog";
import { buildJsonLd, OG_HEIGHT, OG_WIDTH, ogType, pageImage, pageTitle, type PageMeta } from "@/lib/seo";
import { siteConfig } from "@/lib/site";
import "../index.css";

type Props = {
  meta: PageMeta;
  noindex?: boolean;
};

const { meta, noindex = false } = Astro.props;
const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
const image = pageImage(meta);
const title = pageTitle(meta);
const buttonBase =
  "inline-flex h-9 items-center justify-center gap-2 whitespace-nowrap rounded-full border px-4 text-sm font-medium transition-[transform,background-color,color,border-color,box-shadow] duration-300 ease-[cubic-bezier(0.16,1,0.3,1)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent/30 active:translate-y-[1px] active:scale-[0.98]";
const ghostButton = `${buttonBase} border-transparent bg-transparent text-ink-600 hover:bg-white/65 hover:text-ink-800`;
---

<!doctype html>
<html lang={siteConfig.language}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={meta.description} />
    {noindex && <meta name="robots" content="noindex" />}
    <link rel="canonical" href={meta.url} />
    <meta name="theme-color" content="#f4efe6" />
    <meta property="og:type" content={ogType(meta)} />
    <meta property="og:site_name" content={siteConfig.title} />
    <meta property="og:title" content={meta.title} />
    <meta property="og:description" content={meta.description} />
    <meta property="og:url" content={meta.url} />
    <meta property="og:image" content={image} />
    <meta property="og:image:width" content={String(OG_WIDTH)} />
    <meta property="og:image:height" content={String(OG_HEIGHT)} />
    <meta property="og:image:alt" content={meta.title} />
    {
      meta.type === "article" && meta.publishedTime && (
        <meta property="article:published_time" content={meta.publishedTime} />
      )
    }
    {
      meta.type === "article" &&
        meta.tags?.map((tag) => <meta property="article:tag" content={tag} />)
    }
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={meta.title} />
    <meta name="twitter:description" content={meta.description} />
    <meta name="twitter:image" content={image} />
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
    <script
      defer
      src="https://cloud.umami.is/script.js"
      data-website-id="8c39c77b-edab-4799-b07e-6638092c01e1"
    ></script>
    <script type="application/ld+json" set:html={JSON.stringify(buildJsonLd(meta))}></script>
  </head>
  <body>
    <div class="relative min-h-screen">
      <div class="grain-overlay"></div>
      <a
        href="#main-content"
        class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-full focus:bg-ink-800 focus:px-4 focus:py-2 focus:text-paper"
      >
        跳到正文
      </a>
      <header class="sticky top-0 z-20 border-b border-[#d8d0c4] bg-[#f7f3eb]/92 backdrop-blur-xl">
        <div class="mx-auto flex max-w-350 items-center justify-between gap-4 px-4 py-4 sm:px-6 lg:px-10">
          <a href="/" class="group inline-flex items-center gap-3">
            <div class="flex h-10 w-10 items-center justify-center overflow-hidden">
              <img
                src="/logo.svg"
                alt="行开心的颠倒世界 logo"
                width="200"
                height="200"
                class="h-10 w-10 object-contain"
              />
            </div>
            <div>
              <p class="text-sm font-medium text-ink-800">{siteConfig.title}</p>
            </div>
          </a>
          <div class="flex items-center gap-2">
            {
              currentPath !== "/" && (
                <a href="/" class={`${ghostButton} hidden sm:inline-flex`}>
                  <svg aria-hidden="true" class="h-4 w-4" viewBox="0 0 15 15" fill="none">
                    <path
                      d="M3.5 2.5h8a1 1 0 0 1 1 1v8.75a.25.25 0 0 1-.4.2L10.5 11.25l-1.6 1.2a.25.25 0 0 1-.3 0L7 11.25l-1.6 1.2a.25.25 0 0 1-.3 0l-1.6-1.2-1.6 1.2a.25.25 0 0 1-.4-.2V3.5a1 1 0 0 1 1-1Z"
                      stroke="currentColor"
                      stroke-linejoin="round"
                    />
                    <path d="M5 5h5M5 7.5h5" stroke="currentColor" stroke-linecap="round" />
                  </svg>
                  返回文章列表
                </a>
              )
            }
            {
              currentPath !== "/projects" && (
                <a href="/projects" class={`${ghostButton} hidden sm:inline-flex`}>
                  <svg aria-hidden="true" class="h-4 w-4" viewBox="0 0 15 15" fill="none">
                    <path
                      d="M7.5 1.75c1.65 1.1 2.7 2.7 2.7 4.55 0 2.1-1.35 3.5-2.7 4.45C6.15 9.8 4.8 8.4 4.8 6.3c0-1.85 1.05-3.45 2.7-4.55Z"
                      stroke="currentColor"
                      stroke-linejoin="round"
                    />
                    <path d="M5.2 9.1 3.5 10.8M9.8 9.1l1.7 1.7M7.5 5.2v.1" stroke="currentColor" stroke-linecap="round" />
                  </svg>
                  工具箱
                </a>
              )
            }
            <SearchDialog client:load />
          </div>
        </div>
      </header>
      <main id="main-content">
        <slot />
      </main>
      <footer class="border-t border-[#d8d0c4] px-4 py-8 sm:px-6 lg:px-10">
        <div class="mx-auto flex max-w-350 flex-col gap-3 text-sm text-ink-500 sm:flex-row sm:items-center sm:justify-between">
          <p>
            人生不该只有一种体验，不应该每个人的生活都像钉子一样专注。做个兴趣广泛、体验丰富的人，同样幸福
          </p>
          <p class="font-mono text-xs uppercase tracking-[0.24em]">
            &copy; {new Date().getFullYear()} XingKaiXin
          </p>
        </div>
      </footer>
    </div>
    <script
      defer
      src="https://static.cloudflareinsights.com/beacon.min.js"
      data-cf-beacon='{"token": "1c3ce5d60e4e4d4a87e9063032aa37af"}'
    ></script>
  </body>
</html>
