---
import "@fontsource/outfit/400.css";
import "@fontsource/outfit/500.css";
import "@fontsource/outfit/700.css";
import "@fontsource/jetbrains-mono/400.css";
import "@fontsource/jetbrains-mono/600.css";
import "cn-fontsource-smiley-sans-oblique-regular/font.css";
import { ClientRouter } from "astro:transitions";
import { HeaderStickers } from "@/components/header-stickers";
import { MobileHeaderMenu } from "@/components/mobile-header-menu";
import { SearchDialog } from "@/components/search-dialog";
import { buildJsonLd, OG_HEIGHT, OG_WIDTH, ogType, pageImage, pageTitle, type PageMeta } from "@/lib/seo";
import { siteConfig } from "@/lib/site";
import "../index.css";

type Props = {
  meta: PageMeta;
  noindex?: boolean;
};

const { meta, noindex = false } = Astro.props;
const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
const image = pageImage(meta);
const title = pageTitle(meta);
const buttonBase =
  "inline-flex h-9 items-center justify-center gap-2 whitespace-nowrap rounded-full border px-4 text-sm font-medium transition-[transform,background-color,color,border-color] duration-(--duration-quick) ease-(--ease-smooth-out) focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent/40 active:scale-[0.97]";
const ghostButton = `${buttonBase} border-transparent bg-transparent text-ink-500 hover:bg-ink-100 hover:text-ink-800`;
const pageTransition = {
  forwards: {
    old: {
      name: "page-slide-out-left",
      duration: "250ms",
      easing: "cubic-bezier(0.22, 1, 0.36, 1)",
      fillMode: "both",
    },
    new: {
      name: "page-slide-in-right",
      duration: "250ms",
      easing: "cubic-bezier(0.22, 1, 0.36, 1)",
      fillMode: "both",
    },
  },
  backwards: {
    old: {
      name: "page-slide-out-right",
      duration: "250ms",
      easing: "cubic-bezier(0.22, 1, 0.36, 1)",
      fillMode: "both",
    },
    new: {
      name: "page-slide-in-left",
      duration: "250ms",
      easing: "cubic-bezier(0.22, 1, 0.36, 1)",
      fillMode: "both",
    },
  },
};
---

<!doctype html>
<html lang={siteConfig.language} transition:name="root" transition:animate="none">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={meta.description} />
    {noindex && <meta name="robots" content="noindex" />}
    <link rel="canonical" href={meta.url} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${siteConfig.title} RSS`}
      href={`${siteConfig.url}/feed.xml`}
    />
    <meta name="theme-color" content="#fafaf7" />
    <script is:inline>
      (function () {
        function readStoredTheme() {
          try {
            var stored = localStorage.getItem("theme");
            return stored === "dark" || stored === "light" ? stored : null;
          } catch {
            return null;
          }
        }

        function applyTheme() {
          var stored = readStoredTheme();
          var theme =
            stored || (matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");
          document.documentElement.dataset.theme = theme;
          var meta = document.querySelector('meta[name="theme-color"]');
          if (meta) {
            meta.setAttribute("content", theme === "dark" ? "#131418" : "#fafaf7");
          }
        }
        applyTheme();
        document.addEventListener("astro:after-swap", applyTheme);
      })();
    </script>
    <meta property="og:type" content={ogType(meta)} />
    <meta property="og:site_name" content={siteConfig.title} />
    <meta property="og:locale" content="zh_CN" />
    <meta property="og:title" content={meta.title} />
    <meta property="og:description" content={meta.description} />
    <meta property="og:url" content={meta.url} />
    <meta property="og:image" content={image} />
    <meta property="og:image:width" content={String(OG_WIDTH)} />
    <meta property="og:image:height" content={String(OG_HEIGHT)} />
    <meta property="og:image:alt" content={meta.title} />
    {
      meta.type === "article" && meta.publishedTime && (
        <meta property="article:published_time" content={meta.publishedTime} />
      )
    }
    {
      meta.type === "article" &&
        meta.tags?.map((tag) => <meta property="article:tag" content={tag} />)
    }
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={meta.title} />
    <meta name="twitter:description" content={meta.description} />
    <meta name="twitter:image" content={image} />
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
    <ClientRouter />
    <script
      defer
      src="https://cloud.umami.is/script.js"
      data-website-id="8c39c77b-edab-4799-b07e-6638092c01e1"
    ></script>
    <script type="application/ld+json" set:html={JSON.stringify(buildJsonLd(meta))}></script>
  </head>
  <body>
    <div class="relative min-h-screen">
      <a
        href="#main-content"
        class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-full focus:bg-ink-800 focus:px-4 focus:py-2 focus:text-paper"
      >
        跳到正文
      </a>
      <header class="sticky top-0 z-20 border-b border-line bg-paper/85 backdrop-blur-xl">
        <HeaderStickers client:idle transition:persist="header-stickers" />
        <div class="relative mx-auto flex max-w-350 items-center justify-between gap-4 px-4 py-4 sm:px-6 lg:px-10">
          <a href="/" class="group inline-flex items-center gap-3">
            <div class="flex h-10 w-10 items-center justify-center overflow-hidden">
              <img
                src="/logo.svg"
                alt="行开心的颠倒世界 logo"
                width="200"
                height="200"
                class="site-logo h-10 w-10 object-contain"
              />
            </div>
            <div>
              <p class="text-sm font-medium text-ink-800">{siteConfig.title}</p>
            </div>
          </a>
          <div class="flex items-center gap-2">
            <div class="hidden items-center gap-2 sm:flex">
              {
                currentPath !== "/" && (
                  <a href="/" class={ghostButton}>
                    <svg aria-hidden="true" class="h-4 w-4" viewBox="0 0 15 15" fill="none">
                      <path
                        d="M3.5 2.5h8a1 1 0 0 1 1 1v8.75a.25.25 0 0 1-.4.2L10.5 11.25l-1.6 1.2a.25.25 0 0 1-.3 0L7 11.25l-1.6 1.2a.25.25 0 0 1-.3 0l-1.6-1.2-1.6 1.2a.25.25 0 0 1-.4-.2V3.5a1 1 0 0 1 1-1Z"
                        stroke="currentColor"
                        stroke-linejoin="round"
                      />
                      <path d="M5 5h5M5 7.5h5" stroke="currentColor" stroke-linecap="round" />
                    </svg>
                    返回文章列表
                  </a>
                )
              }
              {
                currentPath !== "/projects" && (
                  <a href="/projects/" class={ghostButton}>
                    <svg aria-hidden="true" class="h-4 w-4" viewBox="0 0 15 15" fill="none">
                      <path
                        d="M7.5 1.75c1.65 1.1 2.7 2.7 2.7 4.55 0 2.1-1.35 3.5-2.7 4.45C6.15 9.8 4.8 8.4 4.8 6.3c0-1.85 1.05-3.45 2.7-4.55Z"
                        stroke="currentColor"
                        stroke-linejoin="round"
                      />
                      <path d="M5.2 9.1 3.5 10.8M9.8 9.1l1.7 1.7M7.5 5.2v.1" stroke="currentColor" stroke-linecap="round" />
                    </svg>
                    工具箱
                  </a>
                )
              }
              {
                currentPath !== "/about" && (
                  <a href="/about/" class={ghostButton}>
                    <svg aria-hidden="true" class="h-4 w-4" viewBox="0 0 15 15" fill="none">
                      <circle cx="7.5" cy="5" r="2.25" stroke="currentColor" stroke-linejoin="round" />
                      <path
                        d="M2.75 12.5c.8-2.2 2.65-3.5 4.75-3.5s3.95 1.3 4.75 3.5"
                        stroke="currentColor"
                        stroke-linecap="round"
                      />
                    </svg>
                    关于
                  </a>
                )
              }
              <SearchDialog client:idle />
            </div>
            <button
              type="button"
              data-theme-toggle
              aria-label="切换亮暗模式"
              class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-transparent text-ink-500 transition-[transform,background-color,color] duration-(--duration-quick) ease-(--ease-smooth-out) hover:bg-ink-100 hover:text-ink-800 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent/40 active:scale-[0.92]"
            >
              <svg aria-hidden="true" class="h-4 w-4 dark:hidden" viewBox="0 0 15 15" fill="none">
                <circle cx="7.5" cy="7.5" r="3" stroke="currentColor" />
                <path
                  d="M7.5 1.5v1.5M7.5 12v1.5M13.5 7.5H12M3 7.5H1.5M11.75 3.25l-1.06 1.06M4.31 10.69l-1.06 1.06M11.75 11.75l-1.06-1.06M4.31 4.31 3.25 3.25"
                  stroke="currentColor"
                  stroke-linecap="round"
                />
              </svg>
              <svg aria-hidden="true" class="hidden h-4 w-4 dark:block" viewBox="0 0 15 15" fill="none">
                <path
                  d="M12.9 9.4A5.75 5.75 0 0 1 5.6 2.1a5.75 5.75 0 1 0 7.3 7.3Z"
                  stroke="currentColor"
                  stroke-linejoin="round"
                />
              </svg>
            </button>
            <MobileHeaderMenu currentPath={currentPath} client:idle />
          </div>
        </div>
      </header>
      <main id="main-content" transition:name="page-content" transition:animate={pageTransition}>
        <slot />
      </main>
      <footer class="border-t border-line px-4 py-8 sm:px-6 lg:px-10">
        <div class="mx-auto flex max-w-350 flex-col gap-3 text-sm text-ink-500 sm:flex-row sm:items-center sm:justify-between">
          <p>
            {siteConfig.motto}
          </p>
          <p class="font-mono text-xs uppercase tracking-[0.24em]">
            &copy; {new Date().getFullYear()} XingKaiXin
          </p>
        </div>
      </footer>
    </div>
    <script>
      document.addEventListener("astro:before-preparation", (event) => {
        const isReturningToPostList =
          event.from.pathname.startsWith("/posts/") && event.to.pathname === "/";
        if (isReturningToPostList) {
          event.direction = "back";
        }
      });

      document.addEventListener("click", (event) => {
        const button = (event.target as HTMLElement).closest("[data-theme-toggle]");
        if (!button) {
          return;
        }

        const root = document.documentElement;
        const next = root.dataset.theme === "dark" ? "light" : "dark";
        const apply = () => {
          root.dataset.theme = next;
          document
            .querySelector('meta[name="theme-color"]')
            ?.setAttribute("content", next === "dark" ? "#131418" : "#fafaf7");
          try {
            localStorage.setItem("theme", next);
          } catch {
            // 偏好持久化是 best-effort，存储禁用时仍保留当前页面的主题。
          }
        };

        apply();
      });
    </script>
    <script
      defer
      src="https://static.cloudflareinsights.com/beacon.min.js"
      data-cf-beacon='{"token": "1c3ce5d60e4e4d4a87e9063032aa37af"}'
    ></script>
  </body>
</html>
