---
// header 底部的赛车：
// - cruise：首页，纯 CSS 缓慢向前巡航
// - progress：文章页，滚动进度驱动横向位移，尾部拖一条 accent 进度轨迹
type Props = {
  mode: "cruise" | "progress";
};

const { mode } = Astro.props;
---

<div class="track-lane pointer-events-none sticky top-[73px] z-10 h-0" aria-hidden="true">
  {mode === "progress" && (
    <div data-track-trail class="track-trail absolute inset-x-0 top-0 h-[2px] origin-left scale-x-0 bg-accent/60" />
  )}
  <div data-track-car data-mode={mode} class="track-car absolute left-0 top-0"></div>
  <img src="/finish-flag.png" alt="" aria-hidden="true" class="track-flag absolute right-3 top-0 h-[26px] w-auto dark:invert" />
</div>

<script>
  import confetti from "canvas-confetti";

  const CRUISE_DURATION = 22; // 秒，与下方 CSS animation 时长保持一致
  const CRUISE_KEY = "track-car-cruise-start";

  // 巡航模式跨页面连续：共享会话起点时间戳，用负 animation-delay 把 CSS 循环动画
  // 对齐到本次会话已流逝的相位，页面跳转后接着跑而非从头开始。
  function alignCruise() {
    const car = document.querySelector<HTMLElement>('[data-track-car][data-mode="cruise"]');
    if (!car) {
      return;
    }
    let start = Number(sessionStorage.getItem(CRUISE_KEY));
    if (!Number.isFinite(start) || start <= 0) {
      start = Date.now();
      sessionStorage.setItem(CRUISE_KEY, String(start));
    }
    const offset = ((Date.now() - start) / 1000) % CRUISE_DURATION;
    car.style.animationDelay = `-${offset}s`;
  }

  function readProgress() {
    const { scrollTop, scrollHeight, clientHeight } = document.documentElement;
    const max = scrollHeight - clientHeight;
    return max > 0 ? Math.min(scrollTop / max, 1) : 0;
  }

  // 冲线礼花：从格子旗实际位置爆发一次小型 confetti
  function celebrate(lane: HTMLElement | null) {
    const flag = lane?.querySelector<HTMLElement>(".track-flag");
    if (!flag) {
      return;
    }
    const rect = flag.getBoundingClientRect();
    confetti({
      particleCount: 50,
      spread: 60,
      startVelocity: 28,
      scalar: 0.75,
      disableForReducedMotion: true,
      origin: {
        x: (rect.left + rect.width / 2) / window.innerWidth,
        y: (rect.top + rect.height / 2) / window.innerHeight,
      },
    });
  }

  let celebrated = false;
  function render() {
    const car = document.querySelector<HTMLElement>('[data-track-car][data-mode="progress"]');
    if (!car) {
      return;
    }
    const lane = car.parentElement;
    const trail = lane?.querySelector<HTMLElement>("[data-track-trail]");
    const progress = readProgress();
    const travel = Math.max((lane?.clientWidth ?? 0) - car.offsetWidth, 0);
    car.style.transform = `translateX(${travel * progress}px)`;
    if (trail) {
      trail.style.transform = `scaleX(${progress})`;
    }
    // 满进度首次到达才放礼花；回滚一段后重新武装，读到底可再次庆祝
    if (progress >= 1 && !celebrated) {
      celebrated = true;
      celebrate(lane);
    } else if (progress < 0.99) {
      celebrated = false;
    }
  }

  let frame = 0;
  function schedule() {
    if (frame) {
      return;
    }
    frame = requestAnimationFrame(() => {
      frame = 0;
      render();
    });
  }

  function init() {
    celebrated = false;
    alignCruise();
    schedule();
  }

  init();
  window.addEventListener("scroll", schedule, { passive: true });
  window.addEventListener("resize", schedule);
  document.addEventListener("astro:page-load", init);
</script>

<style>
  /* 赛道尽头的终点线，上下 + 左右镜像 */
  .track-flag {
    transform: scale(-1, -1);
  }

  .track-car {
    height: 22px;
    aspect-ratio: 512 / 118;
    background-color: var(--color-accent);
    -webkit-mask: url("/f1-car.png") center / contain no-repeat;
    mask: url("/f1-car.png") center / contain no-repeat;
    will-change: transform;
  }

  /* 从视口左侧驶入，横穿后从右侧驶离，边界回绕都在屏外完成，呈现持续向前的巡航 */
  .track-car[data-mode="cruise"] {
    animation: track-car-cruise 22s linear infinite;
  }

  @keyframes track-car-cruise {
    from {
      transform: translateX(-120px);
    }
    to {
      transform: translateX(100vw);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .track-car[data-mode="cruise"] {
      animation: none;
      transform: translateX(24px);
    }
  }
</style>
