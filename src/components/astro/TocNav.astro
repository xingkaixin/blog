---
import type { TocItem } from "@/lib/markdown";

type Props = {
  items: TocItem[];
};

const { items } = Astro.props;
---

{
  items.length > 0 && (
    <>
      <div
        data-toc-scroll
        class="card hidden rounded-2xl p-5 lg:block lg:max-h-[calc(100vh-8rem)] lg:overflow-y-auto"
      >
        <p class="mb-4 font-mono text-xs uppercase tracking-[0.28em] text-ink-400">导览</p>
        <nav class="space-y-2">
          {items.map((item) => (
            <a
              data-toc-link={item.id}
              href={`#${item.id}`}
              class:list={[
                "block rounded-xl border border-transparent px-3 py-2 text-sm text-ink-500 transition-colors duration-(--duration-quick) hover:bg-accent/8 hover:text-ink-800",
                item.depth === 3 && "ml-4",
              ]}
            >
              {item.text}
            </a>
          ))}
        </nav>
      </div>
      <details class="rounded-2xl border border-line bg-surface p-5 lg:hidden">
        <summary class="cursor-pointer list-none text-sm font-medium text-ink-700">
          展开导览
        </summary>
        <nav class="mt-4 space-y-2">
          {items.map((item) => (
            <a
              data-toc-link={item.id}
              href={`#${item.id}`}
              class:list={["block text-sm text-ink-500", item.depth === 3 && "ml-4"]}
            >
              {item.text}
            </a>
          ))}
        </nav>
      </details>
      <script>
        import { resolveActiveTocId, TOC_ACTIVE_OFFSET } from "@/lib/toc-active";

        const activeClasses = [
          "border-accent/12",
          "bg-accent/10",
          "font-semibold",
          "text-ink-800",
          "shadow-[inset_3px_0_0_var(--accent)]",
        ];
        const inactiveClasses = ["border-transparent", "text-ink-500"];

        function setActive(links: Element[], id: string) {
          for (const link of links) {
            const isActive = link.getAttribute("data-toc-link") === id;
            link.setAttribute("aria-current", isActive ? "location" : "false");
            for (const className of activeClasses) {
              link.classList.toggle(className, isActive);
            }
            for (const className of inactiveClasses) {
              link.classList.toggle(className, !isActive);
            }
          }

          const desktopNav = document.querySelector("[data-toc-scroll]");
          const activeLink = links.find((link) => link.getAttribute("data-toc-link") === id);
          if (
            desktopNav instanceof HTMLElement &&
            activeLink instanceof HTMLElement &&
            desktopNav.contains(activeLink)
          ) {
            desktopNav.scrollTo({
              top: activeLink.offsetTop - desktopNav.clientHeight / 2 + activeLink.clientHeight / 2,
              behavior: "smooth",
            });
          }
        }

        let previousActiveId: string | null = null;
        let animationFrame = 0;

        function updateActiveHeading() {
          const links = Array.from(document.querySelectorAll("[data-toc-link]"));
          if (!links.length) {
            return;
          }

          const ids = [...new Set(links.map((link) => link.getAttribute("data-toc-link")))];
          const headings = ids
            .map((id) => (id ? document.getElementById(id) : null))
            .filter((heading): heading is HTMLElement => Boolean(heading));

          if (!headings.length) {
            return;
          }

          const visibleIds = headings
            .filter((heading) => heading.getBoundingClientRect().top <= TOC_ACTIVE_OFFSET)
            .map((heading) => heading.id);
          const activeId = resolveActiveTocId(
            headings.map((heading) => heading.id),
            visibleIds,
            previousActiveId,
          );

          if (activeId && activeId !== previousActiveId) {
            previousActiveId = activeId;
            setActive(links, activeId);
          }
        }

        function scheduleUpdate() {
          if (animationFrame) {
            return;
          }
          animationFrame = requestAnimationFrame(() => {
            animationFrame = 0;
            updateActiveHeading();
          });
        }

        scheduleUpdate();
        window.addEventListener("scroll", scheduleUpdate, { passive: true });
        document.addEventListener("astro:page-load", scheduleUpdate);
      </script>
    </>
  )
}
