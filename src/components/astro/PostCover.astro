---
import { resolveCover, type ResponsiveCover } from "@/lib/covers";

type Props = {
  src: string;
  alt: string;
  priority?: boolean;
  class?: string;
  imageClass?: string;
  responsive?: ResponsiveCover | null;
};

const {
  src,
  alt,
  priority = false,
  class: className,
  imageClass,
  responsive = resolveCover(src),
} = Astro.props;
const imageClassName = ["block h-auto w-full max-w-full", imageClass].filter(Boolean).join(" ");
---

<div class:list={["w-full max-w-full overflow-hidden", className]}>
  {
    responsive ? (
      <picture>
        <source srcset={responsive.mobile} media="(max-width: 639px)" />
        <source srcset={responsive.desktop} media="(max-width: 1023px)" />
        <img
          src={responsive.full}
          alt={alt}
          loading={priority ? "eager" : "lazy"}
          fetchpriority={priority ? "high" : undefined}
          class={imageClassName}
        />
      </picture>
    ) : (
      <img
        src={src}
        alt={alt}
        loading={priority ? "eager" : "lazy"}
        fetchpriority={priority ? "high" : undefined}
        class={imageClassName}
      />
    )
  }
</div>
