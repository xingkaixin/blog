---
import PostCard from "@/components/astro/PostCard.astro";
import SiteLayout from "@/layouts/SiteLayout.astro";
import { getPublishedPosts, toPostMeta } from "@/lib/astro-posts";
import { siteConfig } from "@/lib/site";

const posts = (await getPublishedPosts()).map(toPostMeta);
const meta = {
  title: siteConfig.title,
  description: siteConfig.description,
  url: siteConfig.url,
  type: "website" as const,
};
---

<SiteLayout meta={meta}>
  <section class="px-4 pb-20 pt-10 sm:px-6 lg:px-10 lg:pt-14">
    <div class="mx-auto max-w-[1400px] space-y-8">
      <div>
        <p class="text-xs uppercase tracking-[0.28em] text-ink-400">Articles</p>
        <h1 class="mt-3 text-4xl text-ink-800 sm:text-5xl">
          {siteConfig.title}
        </h1>
        <p class="mt-3 max-w-[44ch] text-base leading-8 text-ink-600">
          {siteConfig.description}
        </p>
      </div>
      {
        posts.length > 0 ? (
          <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
            {posts.map((post, index) => <PostCard post={post} index={index} />)}
          </div>
        ) : (
          <div class="space-y-3">
            <p class="text-xs uppercase tracking-[0.28em] text-ink-400">暂无文章</p>
            <h2 class="text-4xl text-ink-800">还没有发布文章</h2>
          </div>
        )
      }
    </div>
  </section>
</SiteLayout>
