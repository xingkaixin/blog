---
import SiteLayout from "@/layouts/SiteLayout.astro";
import { siteConfig } from "@/lib/site";

const meta = {
  title: "页面未找到",
  description: "这篇内容可能已经删除、移动，或者链接已经过期。",
  url: `${siteConfig.url}/404`,
  type: "webpage" as const,
};
---

<SiteLayout meta={meta} noindex>
  <section class="px-4 py-24 sm:px-6 lg:px-10">
    <div class="card mx-auto max-w-xl rounded-3xl px-8 py-12 text-center">
      <p class="font-mono text-xs uppercase tracking-[0.32em] text-ink-500">404</p>
      <h1 class="mt-4 font-display text-4xl text-ink-800">页面未找到</h1>
      <p class="mt-4 leading-8 text-ink-600">这篇内容可能已经删除、移动，或者链接已经过期。</p>
      <a
        href="/"
        class="mt-8 inline-flex h-11 items-center justify-center rounded-full border border-accent bg-accent px-6 text-sm font-medium text-white transition-colors hover:bg-ink-800 hover:text-paper focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent/40 focus-visible:ring-offset-2"
      >
        返回首页
      </a>
    </div>
  </section>
</SiteLayout>
