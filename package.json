{
  "name": "xingkaixin-blog",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun run build:search && bun run build:covers && bun run build:post-images && bun run build:og && astro build && bun run build:sitemap",
    "build:covers": "bun scripts/generate-covers.ts",
    "build:og": "bun scripts/generate-og-images.ts",
    "build:post-images": "bun scripts/generate-post-images.ts",
    "build:search": "bun scripts/generate-search-index.ts",
    "build:sitemap": "bun scripts/generate-sitemap.ts",
    "deploy": "bun run build && bun run wrangler",
    "dev": "astro dev",
    "isok": "bun run lint && bun run lint:format && bun run test",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --type-aware --fix",
    "lint:format": "oxfmt --write",
    "preview": "astro preview",
    "test": "vitest run",
    "wrangler": "wrangler pages deploy dist --project-name=blog"
  },
  "dependencies": {
    "@fontsource/jetbrains-mono": "^5.1.1",
    "@fontsource/outfit": "^5.1.1",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-icons": "^1.3.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gray-matter": "^4.0.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.3.1",
    "tegaki": "^0.15.0"
  },
  "devDependencies": {
    "@astrojs/react": "^5.0.4",
    "@tailwindcss/typography": "^0.5.16",
    "@tailwindcss/vite": "^4.1.12",
    "@types/node": "^25.5.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "astro": "^6.3.1",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0",
    "oxlint-tsgolint": "^0.16.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.12",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.41.0",
    "vite": "^8.0.0",
    "vite-imagetools": "^10.0.0",
    "vitest": "^4.1.0"
  }
}
