{
  "name": "xingkaixin-blog",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun run build:search && bun run build:covers && bun run build:post-images && bun run build:og && astro build --force && bun run build:sitemap && bun run build:feed && bun run build:clean-dist",
    "build:clean-dist": "bun scripts/clean-dist-png.ts",
    "build:covers": "bun scripts/generate-covers.ts",
    "build:feed": "bun scripts/generate-feed.ts",
    "build:og": "bun scripts/generate-og-images.ts",
    "build:post-images": "bun scripts/generate-post-images.ts",
    "build:search": "bun scripts/generate-search-index.ts",
    "build:sitemap": "bun scripts/generate-sitemap.ts",
    "deploy": "bun run build && bun run wrangler",
    "dev": "astro dev",
    "format": "oxfmt --write",
    "format:check": "oxfmt --check",
    "generate:signature-glyphs": "bun scripts/generate-signature-glyphs.ts",
    "isok": "bun run lint && bun run format:check && bun run typecheck && bun run test",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --type-aware --fix",
    "postinstall": "bun scripts/patch-smiley-font.ts",
    "preview": "astro preview",
    "test": "vitest run",
    "typecheck": "astro check",
    "wrangler": "wrangler pages deploy dist --project-name=blog"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/outfit": "^5.2.8",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cn-fontsource-smiley-sans-oblique-regular": "^1.0.1",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.6.0",
    "tegaki": "^0.20.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/markdown-remark": "^7.2.1",
    "@astrojs/react": "^6.0.1",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.2",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "astro": "^7.0.7",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "oxlint-tsgolint": "^0.24.0",
    "satori": "^0.28.1",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
